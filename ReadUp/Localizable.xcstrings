    "auth.termsBody" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "By creating an account on ReadUp, you agree to the following terms:\n\n1. Data Collection: We collect the books you search and save, to provide a personalized reading experience.\n\n2. AI Assistant: The AI recommendations are generated based on your reading preferences. Responses may occasionally be inaccurate.\n\n3. Privacy: We do not sell your personal data to third parties. Your reading data is yours.\n\n4. Usage: You agree not to misuse our services or help anyone else do so.\n\n(These are generic placeholder terms for demonstration purposes.)"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ao criar uma conta no ReadUp, você concorda com os seguintes termos:\n\n1. Coleta de Dados: Coletamos os livros que você busca e salva para oferecer uma experiência de leitura personalizada.\n\n2. Assistente IA: As recomendações são geradas com base em suas preferências de leitura. As respostas podem ser imprecisas ocasionalmente.\n\n3. Privacidade: Não vendemos seus dados pessoais a terceiros. Seus dados de leitura são seus.\n\n4. Uso: Você concorda em não usar indevidamente nossos serviços.\n\n(Estes são termos genéricos para fins de demonstração.)"
          }
        }
      }
    },
    "auth.termsTitle" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Terms of Service & Privacy Policy"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Termos de Uso e Política de Privacidade"
          }
        }
      }
    },
