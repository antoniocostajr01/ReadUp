    "/ %lld %@" : {
      "comment" : "A slash followed by the total number of pages in the book.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "/ %1$lld %2$@"
          }
        }
      }
    },
    "/ %lld pages" : {
      "comment" : "A slash followed by the total number of pages in a book.",
      "isCommentAutoGenerated" : true
    },
    "%@" : {
      "comment" : "A label that says \"Select status\"",
      "isCommentAutoGenerated" : true
    },
    "%lld" : {
      "comment" : "A label that shows the number of pages read in a book. The argument is the number of pages read.",
      "isCommentAutoGenerated" : true
    },
    "%lld%%" : {
      "comment" : "A label showing the percentage of a book that has been read. The argument is the percentage of the book that has been read.",
      "isCommentAutoGenerated" : true
    },
    "+%lld pages" : {
      "comment" : "A label that shows the number of pages read in a session. The argument is the number of pages read.",
      "isCommentAutoGenerated" : true
    },
